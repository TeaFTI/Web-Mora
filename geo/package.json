  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "drizzle:generate": "dotenvx run -- drizzle-kit generate",
    "drizzle:migrate": "dotenvx run -- drizzle-kit migrate",
    "drizzle:plant": "dotenvx run -- npx tsx ./src/_drizzle/plant.ts",
    "drizzle:unplant": "dotenvx run -- npx tsx ./src/_drizzle/unplant.ts",
    "drizzle:all": "dotenvx run -- sh -c 'drizzle-kit generate && drizzle-kit migrate && npx tsx ./src/_drizzle/plant.ts'",
    "betterauth:generate": "npx auth@latest generate --config ./src/_betterauth/auth.ts --output ./src/_drizzle/schema/better-auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4",
